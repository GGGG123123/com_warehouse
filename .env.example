# SuperBizAgent example environment
# Copy this file to .env and fill in your own secrets before running locally.

# App
APP_NAME=SuperBizAgent
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=9900

# LLM
DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key
DASHSCOPE_MODEL=replace_with_your_chat_model
DASHSCOPE_EMBEDDING_MODEL=replace_with_your_embedding_model
RAG_MODEL=replace_with_your_rag_model

# Multimodal
MULTIMODAL_MODEL=replace_with_your_multimodal_model
MULTIMODAL_MAX_FILE_BYTES=10485760
MULTIMODAL_MAX_TEXT_CHARS=12000

# Memory evaluator
MEMORY_EVALUATOR_ENABLED=true
MEMORY_EVALUATOR_MODEL=deepseek-v4-flash
MEMORY_EVALUATOR_STORE_THRESHOLD=0.65
MEMORY_CASE_DUPLICATE_SIMILARITY=0.88
MEMORY_PROCEDURE_DUPLICATE_SIMILARITY=0.90
MEMORY_FOLLOWUP_DUPLICATE_SIMILARITY=0.86

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# RAG
RAG_TOP_K=3
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# MCP
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# Prometheus
PROMETHEUS_BASE_URL=http://127.0.0.1:9090
PROMETHEUS_REQUEST_TIMEOUT=10.0
